# Example environment variables for the STRATO Netlify Function.
# Copy this to a real .env (gitignored) only for local development with
# `netlify dev`. In production, set these in Netlify dashboard:
# Site settings → Build & deploy → Environment → Environment variables.

# Get your key at https://resend.com/api-keys (free tier: 100 emails/day, 3000/month)
RESEND_API_KEY=re_replace_me

# Sender address. Until your domain is verified on Resend, use the default:
#   SENDER_EMAIL=onboarding@resend.dev
# After verifying stratolabs.it on Resend, switch to e.g.:
#   SENDER_EMAIL=demo@stratolabs.it
SENDER_EMAIL=onboarding@resend.dev

# Where the new-demo notification is delivered
DEMO_RECIPIENT_EMAIL=strato.digitalab@gmail.com
